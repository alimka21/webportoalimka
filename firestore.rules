rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - description: string (required, max 500 chars)
    //   - imageUrl: string (required, valid URL)
    //   - link: string (required, valid URL)
    //   - type: string (required, 'free' or 'paid')
    //   - createdAt: timestamp (required, immutable)
    //   - authorUid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "kpbgalimka@gmail.com" && request.auth.token.email_verified == true;
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function uidUnchanged() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == request.auth.uid;
    }

    function uidNotModified() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == resource.data.authorUid;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidProject(data) {
      return hasOnlyAllowedFields(['title', 'description', 'promptText', 'supportUrls', 'imageUrl', 'link', 'type', 'createdAt', 'authorUid', 'isFeatured']) &&
             validStringLength('title', 1, 100) &&
             validStringLength('description', 1, 1000) &&
             isValidUrl(data.imageUrl) &&
             isValidUrl(data.link) &&
             data.type in ['free', 'paid'] &&
             (!('isFeatured' in data) || data.isFeatured is bool) &&
             data.createdAt is timestamp &&
             data.authorUid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      // Anyone can read projects
      allow read: if true;
      
      // Only admin can create projects
      allow create: if isAdmin() && 
                    hasRequiredFields(['title', 'description', 'imageUrl', 'link', 'type', 'createdAt', 'authorUid']) &&
                    isValidProject(request.resource.data) &&
                    uidUnchanged();
                    
      // Only admin can update projects
      allow update: if isAdmin() && 
                    isValidProject(request.resource.data) &&
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt', 'authorUid']);
                    
      // Only admin can delete projects
      allow delete: if isAdmin();
    }
  }
}
